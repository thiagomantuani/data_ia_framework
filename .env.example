# Environments
MINIMAX_API_KEY=
MINIMAX_GROUP_ID=
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
DATABASE_URL=postgresql://user:pass@localhost:5432/dbname

# LLM Configuration
LLM_PROVIDER=minimax
LLM_MODEL=MiniMax-M2.7
LLM_MAX_TOKENS=4096
LLM_TEMPERATURE=0.7

# Pipeline Configuration
PIPELINE_DEFAULT_TIMEOUT=3600
PIPELINE_MAX_WORKERS=4

# Visualization
DASHBOARD_THEME=plotly_dark
EXPORT_FORMAT=png